{
  "name": "douyin-highlight-desktop",
  "version": "0.1.0",
  "description": "Local video library, keyword filter, highlight detection, and FFmpeg export",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.main.json && npm run build:renderer && npm run copy:static && npm run build:preload",
    "build:renderer": "vite build",
    "build:preload": "esbuild src/preload/preload.ts --bundle --platform=node --external:electron --outfile=dist/preload/bundle.js --sourcemap",
    "copy:static": "node scripts/copy-static.mjs",
    "watch": "concurrently \"tsc -w -p tsconfig.main.json\" \"vite build --watch\" \"npm run build:preload -- --watch\"",
    "start": "npm run build && electron .",
    "dev": "concurrently -k \"tsc -w -p tsconfig.main.json\" \"npm run vite:dev\" \"npm run build:preload -- --watch\" \"wait-on dist/main/main.js dist/preload/bundle.js http://127.0.0.1:5173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .\"",
    "vite:dev": "vite --host 127.0.0.1 --port 5173",
    "dev:compile-once": "tsc -p tsconfig.main.json && npm run build:preload",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "pack:mac": "npm run build && electron-builder --dir --mac",
    "pack:win": "npm run build && electron-builder --dir --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.21",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "electron-store": "^8.2.0",
    "ffmpeg-static": "^5.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "build": {
    "appId": "com.douyinhighlight.desktop",
    "productName": "HighlightClip",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/@ffprobe-installer/**"
    ],
    "files": [
      "dist/**/*",
      "static/**/*",
      "build/icon.png",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
